// original test fixture (xvision) — Donchian channel breakout: enter on channel breaks with RSI momentum
//@version=5
strategy("Donchian Breakout", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=10)

dc_len = input.int(20, title="Donchian Length", minval=5, maxval=100)
rsi_len = input.int(14, title="RSI Length", minval=2, maxval=50)
rsi_confirm = input.int(50, title="RSI Momentum Threshold", minval=40, maxval=70)
stop_pct = input.float(2.5, title="Stop Loss %", minval=0.5, maxval=15.0, step=0.5)
profit_pct = input.float(5.0, title="Take Profit %", minval=1.0, maxval=30.0, step=0.5)

rsi_val = ta.rsi(close, rsi_len)
ema_val = ta.ema(close, dc_len)

bull_break = close > ema_val and rsi_val > rsi_confirm
bear_break = close < ema_val and rsi_val < rsi_confirm

if bull_break
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", loss=stop_pct, profit=profit_pct)

if bear_break
    strategy.close("Long")
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", loss=stop_pct, profit=profit_pct)
