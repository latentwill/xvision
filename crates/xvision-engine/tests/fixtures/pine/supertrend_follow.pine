// original test fixture (xvision) — SuperTrend-style trend-following using ATR and direction flips
//@version=5
strategy("SuperTrend Follow", overlay=true)

atr_period = input.int(10, title="ATR Period", minval=1, maxval=50)
factor = input.float(3.0, title="ATR Factor", minval=0.5, maxval=10.0, step=0.5)
var trend_dir = 1

atr_val = ta.sma(high - low, atr_period)
upper_band = (high + low) / 2 + factor * atr_val
lower_band = (high + low) / 2 - factor * atr_val

if close > upper_band
    trend_dir := 1

if close < lower_band
    trend_dir := -1

in_uptrend = trend_dir > 0
in_downtrend = trend_dir < 0

if in_uptrend
    strategy.entry("Long", strategy.long)

if in_downtrend
    strategy.close("Long")
    strategy.entry("Short", strategy.short)
