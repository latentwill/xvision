# VCS
.git
.gitignore
.github

# Rust build outputs
target
**/target
Cargo.lock.bak

# Frontend dependency/build outputs
frontend/web/node_modules
frontend/web/dist
frontend/web/.vite
frontend/web/*.tsbuildinfo
# Vite's real outDir (gitignored local builds). Without this, a stale local
# SPA build rides into the builder stage via `COPY . .` and rust-embed embeds
# its leftover hashed chunks alongside the fresh in-Docker build. Handwritten
# static JS (js/bus.js) is tracked source and must stay in the context.
crates/xvision-dashboard/static
!crates/xvision-dashboard/static/.gitkeep
!crates/xvision-dashboard/static/js
coverage

# Sidecar dependency/build outputs
xvision-agentd/node_modules
xvision-agentd/dist
xvision-agentd/*.tsbuildinfo
**/coverage

# Runtime data (never ship as part of the image), except packaged probe assets.
data/*
!data/probes/
!data/probes/**
# Content-addressed bar-cache probes (64-char hex names) are local-run
# artifacts, not fixtures — keep them out of the image.
data/probes/[0-9a-f]*.parquet
!data/examples/
!data/examples/**
*.db
*.db-journal
*.db-wal
*.db-shm

# Local model weights — too large to bake in; mount at runtime
models

# Git worktrees — large and never needed in the image
.worktrees

# Editor / OS noise
.vscode
.idea
.DS_Store
*.swp

# Notebooks, probes, ad-hoc scratch
notebooks
probes/m0-orderly/target

# Existing docs we don't need inside the image
docs
# Exception: docs/strategies is embedded into the xvision-engine binary at
# compile time via include_dir!(".../docs/strategies"). Must stay in build
# context or the proc macro panics.
!docs/strategies
!docs/strategies/**

# Local env files
.env
.env.local
.env.*.local

# Dockerfiles themselves (copied explicitly when needed). Note: do NOT
# exclude `docker/` — the runtime stage of `Dockerfile` does
# `COPY docker/entrypoint.sh /usr/local/bin/entrypoint.sh`, so the directory
# must be present in the build context. README.md inside docker/ is small.
Dockerfile
docker-compose.yml
.dockerignore
