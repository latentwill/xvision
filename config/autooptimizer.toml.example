# AutoOptimizer configuration for xvn.
# Copy to ~/.xvn/autooptimizer.toml and edit before running `xvn autooptimizer run`.
# All settings are locked in at session start — changes take effect on the next run.

# Minimum improvement a candidate must beat the baseline by to be accepted.
# 0.05 means the candidate must improve Sharpe ratio by at least 5%.
# Must be greater than 0.
min_improvement = 0.05
# Minimum improvement on the holdout (baseline-untouched) window.
# Separate from min_improvement so the out-of-sample bar can be lower than
# the in-sample bar. Defaults to 0.005 (0.5%) when not set.
holdout_min_improvement = 0.005


# Dates held out for final performance checks — never used during evening runs.
# Must not overlap with day_window. Format: "YYYY-MM-DD" (quoted string).
[baseline_untouched_window]
start = "2025-09-01"
end   = "2025-12-01"

# In-sample date range used during each evening run.
# Should not overlap with baseline_untouched_window.
# Keep the span under MAX_WINDOW_DAYS (120) — larger windows are rejected
# at validation because they OOM the backtest (loads every bar into memory).
[day_window]
start = "2025-01-01"
end   = "2025-04-01"

# Optional: lower the minimum-improvement bar if no experiment passes for
# several consecutive evenings. Remove this section to keep min_improvement fixed.
# Each threshold applies to the corresponding evening number (evening 1, 2, 3, …).
[loosening_schedule]
day_n_thresholds = [0.04, 0.03, 0.02]

# The model that writes experiment proposals each evening.
[mutator]
provider    = "anthropic"
model       = "claude-haiku-4-5"
max_retries = 3

# Optional: where lineage data is stored.
# Default is ~/.xvn/lineage if not set.
# lineage_root = "/data/xvn/lineage"
