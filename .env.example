# Copy this file to `.env` and fill in real values.
# .env is gitignored.
# --- Dashboard auth (required for non-loopback binds, Docker, and Tailscale) ---
# Generate with: openssl rand -hex 32
XVN_DASHBOARD_TOKEN=


# --- Alpaca paper trading (M5 in MANUAL.md) ---
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# --- Orderly testnet (M6 in MANUAL.md) ---
ORDERLY_KEY=
ORDERLY_SECRET=
ORDERLY_ACCOUNT_ID=
ORDERLY_BASE_URL=https://testnet-api-evm.orderly.org

# --- Mantle (only needed for the identity image) ---
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_DEPLOYER_KEY=

# --- Optional ---
HF_TOKEN=
RUST_LOG=info
