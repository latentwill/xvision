.DS_Store

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Env / secrets
.env*
!.env.example
*.pem
*.key

# Data / runtime
*.sqlite
*.sqlite3
*.db
data/*
!data/probes/
!data/probes/**
# Content-addressed bar-cache probes (64-char hex names) are local-run artifacts,
# not fixtures. Named fixtures like scenario-*.parquet / test-fixture-*.parquet
# stay tracked.
data/probes/[0-9a-f]*.parquet
!data/examples/
!data/examples/**
logs/
checkpoints/
models/
!models/.gitkeep
*.gguf
*.safetensors
*.bin

# Editor
.vscode/
.idea/
*.swp

# Rust
target/
**/*.rs.bk

# Claude Code runtime state (skills submodule is tracked; lock/local are not)
.claude/scheduled_tasks.lock
.claude/settings.local.json
.claude/hooks/.clippy-tail.log

# Superpowers brainstorming session content (ephemeral mockups + state)
.superpowers/

# Dev-only docs scratch area (design mockups, prototypes, gpt prompts,
# generated mobile artifacts). Repo-root anchored so it doesn't shadow
# nested `docs/` paths like `crates/xvision-dashboard/src/routes/docs/`.
# The in-app wiki lives at `crates/xvision-dashboard/wiki/`, not here.
# NOTE: docs/design/ is tracked for design research and prompts.
/docs/*.md
/docs/*.png
/docs/*.jpg
/docs/*.jpeg
/docs/*.webp
/docs/*.gif
/docs/*.svg
/docs/*.py
/docs/*.js
/docs/*.ts
/docs/*.json
/docs/*.yaml
/docs/*.yml
/docs/*.txt
/docs/superpowers/
!/docs/superpowers/
!/docs/superpowers/evidence/
!/docs/superpowers/evidence/2026-05-24-cortex-flywheels/
!/docs/superpowers/evidence/2026-05-24-cortex-flywheels/**
/docs/scratch/
/docs/mockups/
/docs/prototypes/
/docs/generated/
/docs/mobile/
/docs/.DS_Store
!/docs/design/
!/docs/design/**
# Keep macOS cruft out of the tracked docs/design tree (the negation above re-includes it otherwise)
/docs/design/**/.DS_Store

# NotebookLM research exports — local scratch, not tracked
/docs/NLM/

# Local temp scratch dir
.tmp/

# Git worktrees for parallel team operation (see team/README.md)
.worktrees/
.claude/worktrees/

# Local tool workspaces
.clawpatch/

# Frontend bundle (Vite emits into the dashboard crate; baked at compile time)
crates/xvision-dashboard/static/*
!crates/xvision-dashboard/static/.gitkeep
# Handwritten static JS (SSE label registry, etc.) is tracked source, not build output
!crates/xvision-dashboard/static/js/
!crates/xvision-dashboard/static/js/**
frontend/web/node_modules/
frontend/web/dist/
frontend/web/*.tsbuildinfo
frontend/web/.vite/

# agent-conductor scripts
tools/agent-conductor/scripts/node_modules/
tools/agent-conductor/scripts/package-lock.json

# agent-conductor daemon
tools/agent-conductor/node_modules/
tools/agent-conductor/dist/

# 100x pipeline logs
.100x/
