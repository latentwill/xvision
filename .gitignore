# Rust
target/
**/*.rs.bk

# Claude Code runtime state (skills submodule is tracked; lock/local are not)
.claude/scheduled_tasks.lock
.claude/settings.local.json

# Superpowers brainstorming session content (ephemeral mockups + state)
.superpowers/

# Local design mockups / generated mobile artifacts
docs/design/

# Git worktrees for parallel team operation (see team/README.md)
.worktrees/
.claude/worktrees/

# Local tool workspaces
.clawpatch/

# Frontend bundle (Vite emits into the dashboard crate; baked at compile time)
crates/xvision-dashboard/static/*
!crates/xvision-dashboard/static/.gitkeep
frontend/web/node_modules/
frontend/web/dist/
frontend/web/*.tsbuildinfo
frontend/web/.vite/
