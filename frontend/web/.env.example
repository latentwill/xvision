# Frontend build-time env (Vite `VITE_`-prefixed vars are inlined into the SPA).
# Copy to `.env.local` for local overrides (gitignored). Production defaults are
# baked by Dockerfile.deploy build args.

# Marketplace subgraph GraphQL endpoint (public Goldsky read API). When set, the
# marketplace UI reads real on-chain listings via SubgraphMarketplaceData; when
# unset/empty, it falls back to the fixture client. `live` is a stable Goldsky
# tag that repoints to the latest deployed subgraph version.
VITE_MARKETPLACE_SUBGRAPH_URL=https://api.goldsky.com/api/public/project_cmq8zp6etzmv101xwaeih73lr/subgraphs/xvision-marketplace/live/gn

# Marketplace network: the SPA now selects its chain (id, USDC EIP-712 domain,
# wallet-switch target, explorer links) at RUNTIME from the backend's
# `XVN_CHAIN_ID` (reported by GET /api/marketplace/status). So you normally do
# NOT need to set this — the same prebuilt bundle works on testnet or mainnet
# purely by the backend env. `VITE_MARKETPLACE_NETWORK` (sepolia|mainnet) remains
# only as a build-time FALLBACK for when the backend reports no chain; if you set
# it AND it disagrees with the backend chain, the UI shows a "network mismatch"
# banner (the backend chain wins for signing).
# VITE_MARKETPLACE_NETWORK=sepolia
