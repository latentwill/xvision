#!/usr/bin/env bash
#
# Worktree-isolation guard.
#
# Forbids committing branch/feature work in the PRIMARY (main) checkout.
# This repo runs multiple concurrent agents (claude, codex, 100x, human) in
# the same clone; branch work in the shared main checkout causes HEAD/branch
# collisions (an agent checks out its branch under another's feet, force-pushes,
# etc.). All branch work must happen in an isolated `git worktree`.
#
# Activated by `core.hooksPath=.githooks` (run `scripts/setup-hooks.sh` once;
# the setting lives in the shared config and covers every worktree of the clone).
# See CLAUDE.md → "Worktree isolation (enforced)".
set -euo pipefail

# ── rustfmt drift guard ──────────────────────────────────────────────────────
# Reject commits whose staged workspace Rust files aren't formatted to the repo's
# rustfmt.toml (max_width = 110). Without this, an editor "format on save" or a
# tool that runs rustfmt at a DIFFERENT width (or against an un-normalized tree)
# reflows a large diff (the 2026-06-08 spew). The tree was normalized once with
# `cargo fmt --all`, so this guard now has zero false positives.
#
# Scope: crates/**/*.rs only — that is exactly what `cargo fmt --all` formats.
# Out-of-workspace files (probes/, team/notes/ salvage) are intentionally
# excluded; cargo fmt does not reach them and some don't even parse standalone.
# `--config-path` is passed explicitly so the check is correct even when rustfmt
# config auto-discovery would fail (the original spew's root cause).
# Skip with XVISION_SKIP_FMT_CHECK=1 (rare; e.g. an intentional mass reformat).
if [ "${XVISION_SKIP_FMT_CHECK:-}" != "1" ] && command -v rustfmt >/dev/null 2>&1; then
  fmt_root="$(git rev-parse --show-toplevel)"
  fmt_cfg="$fmt_root/rustfmt.toml"
  fmt_staged="$(git diff --cached --name-only --diff-filter=ACM | grep -E '^crates/.*\.rs$' || true)"
  if [ -n "$fmt_staged" ] && [ -f "$fmt_cfg" ]; then
    set --
    while IFS= read -r f; do
      [ -n "$f" ] && [ -f "$fmt_root/$f" ] && set -- "$@" "$fmt_root/$f"
    done <<EOF_FMT
$fmt_staged
EOF_FMT
    if [ "$#" -gt 0 ] && ! rustfmt --edition 2021 --config-path "$fmt_cfg" --check "$@" >/dev/null 2>&1; then
      cat >&2 <<EOF_FMT_MSG

  ✗ blocked: staged Rust files under crates/ are not formatted to rustfmt.toml
    (max_width = 110). Reformat to the repo config and re-stage:

        cargo fmt                 # from the repo root — picks up rustfmt.toml
      or per file:
        rustfmt --config-path "$fmt_cfg" <file>

    Bypass (rare, e.g. an intentional mass reformat):
        XVISION_SKIP_FMT_CHECK=1 git commit ...

EOF_FMT_MSG
      exit 1
    fi
  fi
fi

# Deliberate escape hatch for the rare, intentional main-checkout commit
# (e.g. a hotfix straight to main, or fixing this hook itself).
if [ "${XVISION_ALLOW_MAIN_COMMIT:-}" = "1" ]; then
  exit 0
fi

# Non-blocking heads-up when the shared cargo target volume is low on space.
# (Builds happen before commits, so this catches "you just filled the disk".)
guard="$(git rev-parse --show-toplevel 2>/dev/null)/scripts/cargo-disk-guard.sh"
[ -x "$guard" ] && "$guard" --warn 2>/dev/null || true

# Identify the primary worktree: in a linked worktree `--git-dir` resolves to
# `<common>/worktrees/<name>` while `--git-common-dir` is `<common>`; in the
# primary worktree the two resolve to the same directory.
git_dir="$(cd "$(git rev-parse --git-dir)" && pwd -P)"
common_dir="$(cd "$(git rev-parse --git-common-dir)" && pwd -P)"
if [ "$git_dir" != "$common_dir" ]; then
  exit 0   # linked worktree — allowed
fi

branch="$(git symbolic-ref --short -q HEAD || echo DETACHED)"

# Commits to these refs in the primary checkout are allowed (release/sync work).
case "$branch" in
  main|master) exit 0 ;;
esac

toplevel="$(git rev-parse --show-toplevel)"
cat >&2 <<EOF

  ✗ blocked: commit on branch '$branch' in the MAIN checkout
    $toplevel

  Branch work must run in an isolated worktree so concurrent agents
  (claude / codex / 100x) don't collide in one working copy:

      git worktree add .worktrees/<name> -b <branch>
      cd .worktrees/<name>
      # remember: export CARGO_TARGET_DIR=\$HOME/.cargo-target/xvision

  (agent-conductor already provisions these: worktreeRoot=.worktrees,
   branch prefix 'agent/'.)

  Deliberate override:  XVISION_ALLOW_MAIN_COMMIT=1 git commit ...

EOF
exit 1
